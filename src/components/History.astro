---
const events = [
  {
    year: '2003',
    title: 'チーム発足',
    desc: '名古屋大学フォーミュラチームFEM、11月に設立。エンジン車両での参戦を開始。',
    highlight: false,
  },
  {
    year: '2014',
    title: '悲願の総合優勝',
    desc: '第12回学生フォーミュラ日本大会で総合優勝を達成。長年の目標を実現。',
    highlight: true,
  },
  {
    year: '2017',
    title: 'EV参戦・初の3連覇へ',
    desc: '第15回大会より電気自動車（EV）クラスへ参戦を開始。初年度からEVクラス1位を獲得。',
    highlight: true,
  },
  {
    year: '2017–2019',
    title: 'EVクラス 第1次3連覇',
    desc: 'EV参戦初年度から3年連続でEVクラス首位を獲得。電動フォーミュラの頂点に立つ。',
    highlight: true,
  },
  {
    year: '2023–2025',
    title: 'EVクラス 第2次3連覇',
    desc: '2023年・2024年・2025年と再び3年連続でEVクラス1位。2度目の3連覇を達成。',
    highlight: true,
  },
];
---

<section id="history" class="py-24 sm:py-32 bg-fem-gray">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="mb-16">
      <p class="text-fem-red text-xs font-bold tracking-[0.3em] uppercase mb-3">History</p>
      <h2 class="text-4xl sm:text-5xl font-black text-white tracking-tight">歩み</h2>
      <div class="w-12 h-0.5 bg-fem-red mt-4"></div>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-[5.5rem] sm:left-32 top-0 bottom-0 w-px bg-white/10 hidden sm:block"></div>

      <div class="space-y-0">
        {events.map((event, i) => (
          <div class="relative flex gap-0 sm:gap-8 group">
            <!-- Year -->
            <div class="w-24 sm:w-32 flex-shrink-0 pt-6 text-right pr-4 sm:pr-8">
              <span class={`text-sm font-bold tabular-nums ${event.highlight ? 'text-fem-red' : 'text-white/30'}`}>
                {event.year}
              </span>
            </div>

            <!-- Dot on timeline -->
            <div class="hidden sm:flex flex-col items-center pt-6">
              <div class={`w-3 h-3 rounded-full border-2 flex-shrink-0 z-10 ${event.highlight ? 'bg-fem-red border-fem-red' : 'bg-fem-dark border-white/20'}`}></div>
              {i < events.length - 1 && <div class="w-px flex-1 bg-transparent min-h-[2rem]"></div>}
            </div>

            <!-- Content -->
            <div class={`flex-1 pb-10 pt-4 sm:pt-5 sm:pl-8 border-l border-white/10 sm:border-0 pl-4 ${i === events.length - 1 ? 'pb-0' : ''}`}>
              <div class={`inline-flex items-center gap-2 mb-2`}>
                {event.highlight && (
                  <span class="w-1 h-1 rounded-full bg-fem-red"></span>
                )}
                <h3 class={`font-bold text-base sm:text-lg ${event.highlight ? 'text-white' : 'text-white/60'}`}>
                  {event.title}
                </h3>
              </div>
              <p class="text-white/40 text-sm leading-relaxed">{event.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
