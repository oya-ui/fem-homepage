---
---

<section
  id="top"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-fem-dark"
>
  <!-- Banner background image -->
  <div class="absolute inset-0">
    <img
      src="images/banner.jpg"
      alt="FEM Formula Car"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/60 to-fem-dark"></div>
  </div>

  <!-- Red accent line top -->
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-fem-red to-transparent"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 text-center pt-16">
    <!-- Tag line -->
    <div class="inline-flex items-center gap-2 bg-fem-red/10 border border-fem-red/30 rounded-full px-4 py-1.5 mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-fem-red animate-pulse"></span>
      <span class="text-fem-red text-xs font-semibold tracking-widest uppercase">EVクラス 2度の3連覇達成</span>
    </div>

    <!-- Main heading -->
    <h1 class="text-5xl sm:text-7xl md:text-8xl font-black tracking-tighter mb-4 leading-none">
      <span class="text-white">名古屋大学</span><br />
      <span class="text-fem-red">フォーミュラチーム</span><br />
      <span class="text-white">FEM</span>
    </h1>

    <!-- Sub heading -->
    <p class="text-white/50 text-sm sm:text-base font-medium tracking-widest uppercase mt-6 mb-4">
      Formula Entertainment Manufacturer
    </p>

    <!-- Description -->
    <p class="text-white/60 text-base sm:text-lg max-w-2xl mx-auto mt-4 mb-10 leading-relaxed">
      学生フォーミュラ日本大会、全競技1位を目標に。<br class="hidden sm:block" />
      ゼロから作り上げるEVフォーミュラカーで世界と戦う。
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#about"
        class="btn btn-primary rounded-none px-8 py-3 text-sm font-bold tracking-widest uppercase border-0 bg-fem-red hover:bg-red-700 text-white min-w-[180px]"
      >
        チームを知る
      </a>
      <a
        href="https://lin.ee/94AItlm"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline rounded-none px-8 py-3 text-sm font-bold tracking-widest uppercase border-white/30 text-white/70 hover:bg-white hover:text-black hover:border-white min-w-[180px]"
      >
        お問い合わせ
      </a>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-3 gap-4 sm:gap-8 mt-16 sm:mt-20 max-w-2xl mx-auto border-t border-white/10 pt-10">
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-black text-white">2003</div>
        <div class="text-white/40 text-xs sm:text-sm font-medium mt-1">年 創設</div>
      </div>
      <div class="text-center border-x border-white/10">
        <div class="text-3xl sm:text-4xl font-black text-fem-red">50<span class="text-2xl">+</span></div>
        <div class="text-white/40 text-xs sm:text-sm font-medium mt-1">名 在籍</div>
      </div>
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-black text-white">2×<span class="text-2xl">3</span></div>
        <div class="text-white/40 text-xs sm:text-sm font-medium mt-1">連覇 EV</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-12 bg-gradient-to-b from-white/20 to-transparent"></div>
  </div>
</section>
