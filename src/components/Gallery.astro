---
import { Image } from 'astro:assets';
import photo1 from '../assets/images/photo-1.jpg';
import photo2 from '../assets/images/photo-2.jpg';
import photo3 from '../assets/images/photo-3.jpg';
import photo4 from '../assets/images/photo-4.jpg';
import photo5 from '../assets/images/photo-5.jpg';
import photo6 from '../assets/images/photo-6.png';

const images = [
  { src: photo1, alt: 'FEMマシン', wide: true },
  { src: photo2, alt: 'レース写真', wide: false },
  { src: photo3, alt: '大会当日', wide: false },
  { src: photo4, alt: 'チーム活動', wide: false },
  { src: photo5, alt: 'マシン詳細', wide: false },
  { src: photo6, alt: '活動風景', wide: true },
];
---

<section id="gallery" class="py-24 sm:py-32 bg-fem-gray">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="mb-16">
      <p class="text-fem-red text-xs font-bold tracking-[0.3em] uppercase mb-3">Gallery</p>
      <h2 class="text-4xl sm:text-5xl font-black text-white tracking-tight">ギャラリー</h2>
      <div class="w-12 h-0.5 bg-fem-red mt-4"></div>
    </div>

    <!-- Gallery grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">
      {images.map((image) => (
        <div
          class={`relative overflow-hidden rounded-lg group cursor-pointer bg-fem-dark ${image.wide ? 'col-span-2' : ''}`}
        >
          <Image
            src={image.src}
            alt={image.alt}
            widths={[320, 480, 640, 800, 1200]}
            sizes="(min-width: 768px) 33vw, 50vw"
            quality={72}
            format="webp"
            loading="lazy"
            class={`w-full object-cover transition-transform duration-500 group-hover:scale-105 ${image.wide ? 'aspect-video' : 'aspect-square'}`}
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300"></div>
        </div>
      ))}
    </div>

    <!-- FEM Logo -->
    <div class="mt-12 flex justify-center">
      <img src="/images/fem-logo.png" alt="FEM ロゴ" class="h-16 opacity-60 hover:opacity-100 transition-opacity" />
    </div>
  </div>
</section>
