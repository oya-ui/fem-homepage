---
// 実際の画像は src/assets/images/ に配置してください
// ファイル名の例: machine-2025.jpg, race-2024.jpg など
// Googleドライブから画像をダウンロード後、以下の配列に追加してください

const placeholders = [
  { label: 'マシン全景', aspect: 'wide' },
  { label: 'コックピット', aspect: 'square' },
  { label: 'レース中', aspect: 'square' },
  { label: 'チーム集合', aspect: 'wide' },
  { label: '製作風景', aspect: 'square' },
  { label: '表彰式', aspect: 'square' },
];

// 実画像を追加する場合はこちら（コメントアウト解除）
// import img1 from '../assets/images/machine-2025.jpg';
// const images = [
//   { src: img1, alt: '2025年マシン全景' },
//   ...
// ];
---

<section id="gallery" class="py-24 sm:py-32 bg-fem-gray">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="mb-16">
      <p class="text-fem-red text-xs font-bold tracking-[0.3em] uppercase mb-3">Gallery</p>
      <h2 class="text-4xl sm:text-5xl font-black text-white tracking-tight">ギャラリー</h2>
      <div class="w-12 h-0.5 bg-fem-red mt-4"></div>
      <p class="text-white/40 text-sm mt-4">
        画像追加方法: Googleドライブから画像をダウンロードして <code class="text-white/60 bg-white/5 px-1.5 py-0.5 rounded text-xs">src/assets/images/</code> に配置してください
      </p>
    </div>

    <!-- Gallery grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">
      {placeholders.map((item, i) => (
        <div
          class={`relative overflow-hidden bg-fem-dark border border-white/10 rounded-lg group cursor-pointer ${item.aspect === 'wide' && i === 0 ? 'col-span-2 md:col-span-2' : ''} ${item.aspect === 'wide' && i === 3 ? 'col-span-2 md:col-span-2' : ''}`}
        >
          <!-- Placeholder -->
          <div class={`w-full flex items-center justify-center ${item.aspect === 'wide' ? 'aspect-video' : 'aspect-square'} bg-gradient-to-br from-white/[0.02] to-white/[0.05]`}>
            <div class="text-center">
              <svg class="w-8 h-8 text-white/20 mx-auto mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <span class="text-white/20 text-xs">{item.label}</span>
            </div>
          </div>

          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-fem-red/0 group-hover:bg-fem-red/10 transition-colors duration-300"></div>
        </div>
      ))}
    </div>

    <!-- Note for image replacement -->
    <div class="mt-8 border border-dashed border-white/10 rounded-lg p-6 text-center">
      <p class="text-white/30 text-xs leading-relaxed">
        実際の写真はGoogleドライブフォルダからダウンロードして<br />
        <code class="text-white/50">src/assets/images/</code> に配置し、Gallery.astro の images 配列を更新してください。
      </p>
    </div>
  </div>
</section>
